# ============================================================
# VARIÁVEIS DE PRODUÇÃO — copie para .env e preencha
# NUNCA commite o .env no repositório
# ============================================================

# Banco de dados
POSTGRES_USER=fiurj
POSTGRES_PASSWORD=TROQUE_POR_SENHA_FORTE
POSTGRES_DB=fiurj_plataforma

# JWT — gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=TROQUE_POR_CHAVE_ALEATORIA_64_BYTES
JWT_EXPIRES_IN=1d

# URLs públicas (use seu domínio ou IP da VPS)
FRONTEND_URL=https://sga.fiurj.edu.br
NEXT_PUBLIC_API_URL=https://sga.fiurj.edu.br/api/v1
# Endereço público canônico usado em QR codes/links de validação (carteirinha
# etc.) — sem essa variável, o link cai em window.location.origin (o endereço
# que estava na barra do navegador no momento, que pode ser um IP antigo ou
# interno, não o domínio público real)
NEXT_PUBLIC_WEB_URL=https://sga.fiurj.edu.br

# Sentry (opcional em produção)
SENTRY_DSN=
