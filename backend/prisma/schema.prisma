// =============================================================================
// schema.prisma — FIURJ Plataforma Acadêmica
// Núcleo de Graduação · Fase 0
//
// Campos marcados com // [CENSO] são exigidos pelo Censo da Educação Superior
// (INEP) e devem existir desde o início — nunca remover.
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// ESTRUTURA ACADÊMICA
// =============================================================================

model Curso {
  id                          String   @id @default(uuid())
  nome                        String
  grau                        Grau     // [CENSO] bacharelado | licenciatura | tecnologo
  modalidade                  Modalidade // [CENSO] presencial | EAD
  codigoEmec                  String   @unique // [CENSO]
  cargaHorariaTotal           Int
  prazoIntegralizacaoSemestres Int
  status                      CursoStatus @default(ATIVO)

  criadoEm   DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  matrizesCurriculares MatrizCurricular[]
  alunos               Aluno[]
  processosSeletivos   ProcessoSeletivo[]

  @@map("cursos")
}

model MatrizCurricular {
  id          String              @id @default(uuid())
  cursoId     String
  versao      String
  anoVigencia Int
  status      MatrizStatus        @default(VIGENTE)

  criadoEm   DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  curso       Curso         @relation(fields: [cursoId], references: [id])
  disciplinas Disciplina[]
  alunos      Aluno[]

  @@unique([cursoId, versao])
  @@map("matrizes_curriculares")
}

model Disciplina {
  id                 String   @id @default(uuid())
  matrizCurricularId String
  codigo             String
  nome               String
  cargaHoraria       Int
  creditos           Int
  ementa             String?  @db.Text
  periodoSugerido    Int

  criadoEm   DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  matrizCurricular MatrizCurricular           @relation(fields: [matrizCurricularId], references: [id])
  ofertas          Oferta[]
  prerequisitos    DisciplinaPrerequisito[]   @relation("disciplina")
  dependentes      DisciplinaPrerequisito[]   @relation("prerequisito")
  equiparacoes     MateriaEquiparada[]

  @@unique([matrizCurricularId, codigo])
  @@map("disciplinas")
}

model DisciplinaPrerequisito {
  id            String @id @default(uuid())
  disciplinaId  String
  prerequisitoId String

  disciplina   Disciplina @relation("disciplina",   fields: [disciplinaId],   references: [id])
  prerequisito Disciplina @relation("prerequisito", fields: [prerequisitoId], references: [id])

  @@unique([disciplinaId, prerequisitoId])
  @@map("disciplinas_prerequisitos")
}

// =============================================================================
// PERÍODO LETIVO
// =============================================================================

model PeriodoLetivo {
  id         String              @id @default(uuid())
  ano        Int
  semestre   Semestre            // 1 ou 2
  dataInicio DateTime            @db.Date
  dataFim    DateTime            @db.Date
  status     PeriodoStatus       @default(PLANEJADO)

  criadoEm   DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  ofertas             Oferta[]
  processosSeletivos  ProcessoSeletivo[]
  contratos           ContratoMatricula[]

  @@unique([ano, semestre])
  @@map("periodos_letivos")
}

// =============================================================================
// OFERTA (turma)
// =============================================================================

model Oferta {
  id              String   @id @default(uuid())
  disciplinaId    String
  periodoLetivoId String
  professorId     String
  vagas           Int
  turno           Turno    // [CENSO] manha | tarde | noite | integral
  horario         String?
  sala            String?

  criadoEm   DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  disciplina    Disciplina           @relation(fields: [disciplinaId],    references: [id])
  periodoLetivo PeriodoLetivo        @relation(fields: [periodoLetivoId], references: [id])
  professor     Professor            @relation(fields: [professorId],     references: [id])
  matriculas    MatriculaDisciplina[]

  @@map("ofertas")
}

// =============================================================================
// PESSOAS
// =============================================================================

model Aluno {
  id                 String          @id @default(uuid())
  cursoId            String
  matrizCurricularId String
  ra                 String          @unique  // registro acadêmico
  nome               String
  cpf                String          @unique
  dataNascimento     DateTime        @db.Date
  sexo               Sexo            // [CENSO]
  corRaca            CorRaca         // [CENSO]
  nacionalidade      String          // [CENSO]
  formaIngresso      FormaIngresso   // [CENSO]
  dataIngresso       DateTime        @db.Date // [CENSO]
  situacaoVinculo    SituacaoVinculo @default(CURSANDO) // [CENSO]
  email              String          @unique
  telefone           String?
  cep                String?
  logradouro         String?
  numero             String?
  complemento        String?
  bairro             String?
  uf                 String?         @db.Char(2)
  municipio          String?

  criadoEm   DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  curso            Curso                @relation(fields: [cursoId],            references: [id])
  matrizCurricular MatrizCurricular     @relation(fields: [matrizCurricularId], references: [id])
  usuario          Usuario?
  matriculas       MatriculaDisciplina[]
  consentimentos   ConsentimentoLgpd[]
  requerimentos    Requerimento[]
  contratos        ContratoMatricula[]
  fichaSaude       FichaSaude?
  documentos       DocumentoAluno[]
  equiparacoes     MateriaEquiparada[]
  historicoSituacao HistoricoSituacaoVinculo[]
  protocolos       Protocolo[]
  ocorrencias      Ocorrencia[]
  observacoesFinanceiras ObservacaoFinanceira[]

  @@map("alunos")
}

model Professor {
  id             String          @id @default(uuid())
  nome           String
  cpf            String          @unique
  titulacao      Titulacao       // [CENSO]
  regimeTrabalho RegimeTrabalho  // [CENSO]
  lattes         String?
  email          String          @unique
  telefone       String?

  criadoEm   DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  usuario Usuario?
  ofertas Oferta[]

  @@map("professores")
}

// =============================================================================
// MATRÍCULA E AVALIAÇÃO
// =============================================================================

model MatriculaDisciplina {
  id            String                 @id @default(uuid())
  alunoId       String
  ofertaId      String
  status        MatriculaStatus        @default(MATRICULADO)
  isDependencia Boolean                @default(false)
  dataMatricula DateTime               @default(now()) @db.Date

  criadoEm   DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  aluno     Aluno               @relation(fields: [alunoId],   references: [id])
  oferta    Oferta              @relation(fields: [ofertaId],  references: [id])
  avaliacoes Avaliacao[]
  resultado  ResultadoDisciplina?
  registrosFrequencia RegistroFrequencia[]

  @@unique([alunoId, ofertaId])
  @@map("matriculas_disciplinas")
}

// ── Frequência diária (achado do spike Kirsch: Secretaria > Manutenção de
// Frequência lança presença/falta aula-a-aula, não só o total consolidado
// no fim do período) ─────────────────────────────────────────────────────
model RegistroFrequencia {
  id                    String   @id @default(uuid())
  matriculaDisciplinaId String
  matriculaDisciplina   MatriculaDisciplina @relation(fields: [matriculaDisciplinaId], references: [id])
  data                  DateTime @db.Date
  quantidadeAulas       Int
  faltas                Int
  observacao            String?

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  @@unique([matriculaDisciplinaId, data])
  @@map("registros_frequencia")
}

model Avaliacao {
  id                    String        @id @default(uuid())
  matriculaDisciplinaId String
  tipo                  AvaliacaoTipo
  nota                  Decimal       @db.Decimal(5, 2)
  peso                  Decimal       @db.Decimal(5, 2)

  criadoEm   DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  matriculaDisciplina MatriculaDisciplina @relation(fields: [matriculaDisciplinaId], references: [id])

  @@map("avaliacoes")
}

model ResultadoDisciplina {
  id                    String             @id @default(uuid())
  matriculaDisciplinaId String             @unique
  mediaFinal            Decimal            @db.Decimal(5, 2)
  faltas                Int
  frequenciaPercentual  Decimal            @db.Decimal(5, 2)
  situacao              SituacaoResultado

  criadoEm   DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  matriculaDisciplina MatriculaDisciplina @relation(fields: [matriculaDisciplinaId], references: [id])

  @@map("resultados_disciplinas")
}

// =============================================================================
// AUTH, AUDITORIA E LGPD
// =============================================================================

model Usuario {
  id          String        @id @default(uuid())
  email       String        @unique
  senhaHash   String
  perfil      Perfil
  mfaAtivo    Boolean       @default(false)
  mfaSegredo  String?       // TOTP secret — nunca expor via API
  status      UsuarioStatus @default(ATIVO)

  // Perfil pessoal (auto-servico via /usuarios/me)
  nome        String?
  telefone    String?
  fotoUrl     String?

  // Relações opcionais: um usuário é ou aluno ou professor (nunca os dois)
  alunoId     String?       @unique
  professorId String?       @unique

  criadoEm   DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  aluno     Aluno?     @relation(fields: [alunoId],     references: [id])
  professor Professor? @relation(fields: [professorId], references: [id])
  auditorias Auditoria[]
  avisos     Aviso[]
  mensagensEnviadas  Mensagem[] @relation("MensagensEnviadas")
  mensagensRecebidas Mensagem[] @relation("MensagensRecebidas")

  @@map("usuarios")
}

model Auditoria {
  id          String   @id @default(uuid())
  usuarioId   String?  // null = ação de sistema
  acao        String   // CREATE | UPDATE | DELETE | LOGIN | LOGOUT | etc.
  entidade    String   // nome da tabela/entidade
  entidadeId  String?  // uuid do registro afetado
  dadosAntes  Json?
  dadosDepois Json?
  ip          String?
  userAgent   String?
  criadoEm    DateTime @default(now())

  usuario Usuario? @relation(fields: [usuarioId], references: [id])

  @@index([entidade, entidadeId])
  @@index([usuarioId])
  @@index([criadoEm])
  @@map("auditorias")
}

model ConsentimentoLgpd {
  id          String   @id @default(uuid())
  alunoId     String
  finalidade  String   // ex: "comunicacao_marketing", "compartilhamento_parceiros"
  concedido   Boolean
  data        DateTime @default(now())
  ip          String?

  aluno Aluno @relation(fields: [alunoId], references: [id])

  @@map("consentimentos_lgpd")
}

// =============================================================================
// ENUMS
// =============================================================================

// --- Censo ---
enum Grau {
  BACHARELADO
  LICENCIATURA
  TECNOLOGO
}

enum Modalidade {
  PRESENCIAL
  EAD
  SEMIPRESENCIAL
}

enum Turno {
  MANHA
  TARDE
  NOITE
  INTEGRAL
}

enum Sexo {
  MASCULINO
  FEMININO
  NAO_DECLARADO
}

enum CorRaca {
  BRANCA
  PRETA
  PARDA
  AMARELA
  INDIGENA
  NAO_DECLARADO
}

enum FormaIngresso {
  VESTIBULAR
  ENEM
  TRANSFERENCIA_EXTERNA
  TRANSFERENCIA_INTERNA
  PORTADOR_DIPLOMA
  CONVENIO
  OUTRO
}

enum SituacaoVinculo {
  CURSANDO
  TRANCADO
  FORMADO
  EVADIDO
  TRANSFERIDO_OUT
  FALECIDO
}

enum Titulacao {
  GRADUADO
  ESPECIALISTA
  MESTRE
  DOUTOR
  POS_DOUTOR
}

enum RegimeTrabalho {
  HORISTA
  PARCIAL   // 20h/semana
  INTEGRAL  // 40h/semana
}

// --- Status internos ---
enum CursoStatus {
  ATIVO
  ENCERRADO
}

enum MatrizStatus {
  VIGENTE
  ENCERRADA
}

enum Semestre {
  S1
  S2
}

enum PeriodoStatus {
  PLANEJADO
  EM_ANDAMENTO
  ENCERRADO
}

enum MatriculaStatus {
  MATRICULADO
  PENDENTE_EXAME  // frequência OK, nota < 6.0 — aguardando exame final
  APROVADO
  REPROVADO
  DEPENDENCIA
  TRANCADO
  CANCELADO
}

enum AvaliacaoTipo {
  PROVA
  TRABALHO
  SEMINARIO
  EXAME_FINAL
  OUTRO
}

enum SituacaoResultado {
  APROVADO
  REPROVADO_NOTA
  REPROVADO_FALTA
  REPROVADO_NOTA_E_FALTA
}

enum Perfil {
  ADMIN
  SECRETARIA
  FINANCEIRO
  PROFESSOR
  ALUNO
}

enum UsuarioStatus {
  ATIVO
  INATIVO
  BLOQUEADO
}

// ── Fase 5: Ingresso / Processo Seletivo ──────────────────────────────────────

model ProcessoSeletivo {
  id               String         @id @default(uuid())
  nome             String
  tipo             TipoProcesso
  cursoId          String
  curso            Curso          @relation(fields: [cursoId], references: [id])
  periodoLetivoId  String
  periodoLetivo    PeriodoLetivo  @relation(fields: [periodoLetivoId], references: [id])
  vagas            Int
  dataAbertura     DateTime
  dataEncerramento DateTime
  status           StatusProcesso @default(ABERTO)
  inscricoes       Inscricao[]
  criadoEm         DateTime       @default(now())
  atualizadoEm     DateTime       @updatedAt

  @@map("processos_seletivos")
}

model Candidato {
  id             String      @id @default(uuid())
  nome           String
  cpf            String      @unique
  email          String
  telefone       String?
  dataNascimento DateTime
  sexo           String
  corRaca        String?
  nacionalidade  String      @default("BRASILEIRA")
  inscricoes     Inscricao[]
  criadoEm       DateTime    @default(now())
  atualizadoEm   DateTime    @updatedAt

  @@map("candidatos")
}

model Inscricao {
  id                 String           @id @default(uuid())
  candidatoId        String
  candidato          Candidato        @relation(fields: [candidatoId], references: [id])
  processoSeletivoId String
  processoSeletivo   ProcessoSeletivo @relation(fields: [processoSeletivoId], references: [id])
  status             StatusInscricao  @default(INSCRITO)
  notaEnem           Decimal?
  documentosOk       Boolean          @default(false)
  observacoes        String?
  alunoId            String?          // preenchido ao converter para Aluno
  criadoEm           DateTime         @default(now())
  atualizadoEm       DateTime         @updatedAt

  @@unique([candidatoId, processoSeletivoId])
  @@map("inscricoes")
}

enum TipoProcesso {
  VESTIBULAR
  ENEM
  SEGUNDA_GRADUACAO
  TRANSFERENCIA_EXTERNA
  TRANSFERENCIA_INTERNA
}

enum StatusProcesso {
  ABERTO
  ENCERRADO
  CANCELADO
}


enum StatusInscricao {
  INSCRITO
  EM_ANALISE
  APROVADO
  REPROVADO
  MATRICULADO
  DESISTENTE
}

// ── Fase 7: Secretaria / Requerimentos ───────────────────────────────────────

model Requerimento {
  id           String              @id @default(uuid())
  alunoId      String
  aluno        Aluno               @relation(fields: [alunoId], references: [id])
  tipo         TipoRequerimento
  descricao    String?             @db.Text
  status       StatusRequerimento  @default(ABERTO)
  resposta     String?             @db.Text
  criadoEm     DateTime            @default(now())
  atualizadoEm DateTime            @updatedAt

  @@map("requerimentos")
}

enum TipoRequerimento {
  DECLARACAO_MATRICULA
  HISTORICO_OFICIAL
  TRANCAMENTO
  CANCELAMENTO
  REVISAO_NOTA
  APROVEITAMENTO_DISCIPLINA
  COLACAO_GRAU
  OUTRO
}

enum StatusRequerimento {
  ABERTO
  EM_ANALISE
  DEFERIDO
  INDEFERIDO
  CANCELADO
}

// ── Financeiro ──────────────────────────────────────────────────────────────

model ContratoMatricula {
  id              String         @id @default(uuid())
  alunoId         String
  aluno           Aluno          @relation(fields: [alunoId], references: [id])
  periodoLetivoId String
  periodoLetivo   PeriodoLetivo  @relation(fields: [periodoLetivoId], references: [id])
  valorTotal      Decimal        @db.Decimal(10, 2)
  numeroParcelas  Int
  diaVencimento   Int            // 1–28
  status          StatusContrato @default(ATIVO)
  observacoes     String?        @db.Text
  criadoEm       DateTime       @default(now())
  atualizadoEm   DateTime       @updatedAt

  parcelas Parcela[]

  @@map("contratos_matricula")
}

model Parcela {
  id             String        @id @default(uuid())
  contratoId     String
  contrato       ContratoMatricula @relation(fields: [contratoId], references: [id])
  numero         Int
  valor          Decimal       @db.Decimal(10, 2)
  dataVencimento DateTime      @db.Date
  dataPagamento  DateTime?     @db.Date
  valorPago      Decimal?      @db.Decimal(10, 2)
  status         StatusParcela @default(PENDENTE)
  formaPagamento String?
  observacoes    String?
  criadoEm      DateTime      @default(now())
  atualizadoEm  DateTime      @updatedAt

  @@map("parcelas")
}

enum StatusContrato {
  ATIVO
  SUSPENSO
  CANCELADO
  ENCERRADO
}

enum StatusParcela {
  PENDENTE
  PAGO
  VENCIDO
  CANCELADO
}

// ── Avisos ──────────────────────────────────────────────────────
model Aviso {
  id         String   @id @default(uuid())
  titulo     String
  texto      String
  tag        TagAviso @default(GERAL)
  autorNome  String
  autorId    String?
  usuario    Usuario? @relation(fields: [autorId], references: [id])
  criadoEm  DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  @@map("avisos")
}

enum TagAviso {
  GERAL
  IMPORTANTE
  APENAS_EQUIPE
}

// ── Ficha de Saúde ──────────────────────────────────────────────
// Dado sensível (LGPD, art. 5º II) — acesso restrito a ADMIN/SECRETARIA,
// nunca exposto a PROFESSOR/ALUNO via API.
model FichaSaude {
  id                        String   @id @default(uuid())
  alunoId                   String   @unique
  aluno                     Aluno    @relation(fields: [alunoId], references: [id])
  tipoSanguineo             String?
  alergias                  String?  @db.Text
  medicamentosUso           String?  @db.Text
  deficiencia               String?  // texto livre; ex.: "Auditiva, Visual" (achado da Kirsch)
  planoSaude                String?
  contatoEmergenciaNome     String?
  contatoEmergenciaTelefone String?
  observacoes               String?  @db.Text

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  @@map("fichas_saude")
}

// ── Contas Bancárias ────────────────────────────────────────────
// Cadastro interno de contas da instituição (base pra conciliação futura
// com Asaas na Fase 6b). Não é conta de aluno/fornecedor.
model ContaBancaria {
  id             String            @id @default(uuid())
  banco          String
  agencia        String
  numeroConta    String
  tipoConta      TipoContaBancaria @default(CORRENTE)
  titular        String
  cnpjCpfTitular String?
  saldoInicial   Decimal           @default(0) @db.Decimal(12, 2)
  ativa          Boolean           @default(true)
  observacoes    String?           @db.Text

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  @@map("contas_bancarias")
}

enum TipoContaBancaria {
  CORRENTE
  POUPANCA
  PAGAMENTO
}

// ── Digitalização de Documentos ────────────────────────────────
model DocumentoAluno {
  id          String   @id @default(uuid())
  alunoId     String
  aluno       Aluno    @relation(fields: [alunoId], references: [id])
  tipo        String   // ex.: RG, CPF, Comprovante de Residência, Histórico Escolar, Diploma, Outro
  nomeArquivo String
  url         String
  tamanho     Int      // bytes

  criadoEm DateTime @default(now())

  @@map("documentos_aluno")
}

// ── Unidades ────────────────────────────────────────────────────
// Catálogo simples de referência (não é multi-tenancy — os dados continuam
// todos numa base única; achado da Kirsch confirmou 2 unidades cadastradas:
// FIURJ Campos Centro e UAL Lisboa).
model Unidade {
  id     String  @id @default(uuid())
  nome   String
  cidade String?
  uf     String? @db.Char(2)
  ativa  Boolean @default(true)

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  @@map("unidades")
}

// ── Receitas (catálogo financeiro) ───────────────────────────────
model CategoriaReceita {
  id        String  @id @default(uuid())
  nome      String
  descricao String?
  ativa     Boolean @default(true)

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  @@map("categorias_receita")
}

// ── Matérias Equiparadas ─────────────────────────────────────────
// Registro de aproveitamento de disciplina cursada em outra instituição/
// curso (transferência, portador de diploma). Documental — não gera
// MatriculaDisciplina/Oferta automaticamente; não entra no cálculo de CR.
model MateriaEquiparada {
  id                 String     @id @default(uuid())
  alunoId            String
  aluno              Aluno      @relation(fields: [alunoId], references: [id])
  disciplinaId       String
  disciplina         Disciplina @relation(fields: [disciplinaId], references: [id])
  instituicaoOrigem  String
  disciplinaOrigem   String
  cargaHorariaOrigem Int?
  dataAprovacao      DateTime   @db.Date
  observacoes        String?    @db.Text

  criadoEm DateTime @default(now())

  @@map("materias_equiparadas")
}

// ── Histórico de Mudança de Situação de Vínculo ─────────────────
model HistoricoSituacaoVinculo {
  id               String          @id @default(uuid())
  alunoId          String
  aluno            Aluno           @relation(fields: [alunoId], references: [id])
  situacaoAnterior SituacaoVinculo
  situacaoNova     SituacaoVinculo
  motivo           String?
  data             DateTime        @db.Date
  usuarioId        String?

  criadoEm DateTime @default(now())

  @@map("historico_situacao_vinculo")
}

// ── Protocolo (achado do spike Kirsch: menu "Protocolo") ────────
// Registro genérico de protocolo administrativo — mais amplo que Requerimento
// (que tem tipo fixo); Protocolo pode ou não estar ligado a um aluno.
model TipoProtocolo {
  id    String  @id @default(uuid())
  nome  String
  ativo Boolean @default(true)

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  protocolos Protocolo[]

  @@map("tipos_protocolo")
}

model Protocolo {
  id                String          @id @default(uuid())
  numero            String          @unique
  tipoId            String
  tipo              TipoProtocolo   @relation(fields: [tipoId], references: [id])
  alunoId           String?
  aluno             Aluno?          @relation(fields: [alunoId], references: [id])
  assunto           String
  descricao         String?         @db.Text
  status            StatusProtocolo @default(ABERTO)
  dataAbertura       DateTime       @default(now())
  dataConclusao      DateTime?
  usuarioAberturaId String?

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  @@map("protocolos")
}

enum StatusProtocolo {
  ABERTO
  EM_ANDAMENTO
  CONCLUIDO
  CANCELADO
}

// ── Ocorrências (achado do spike Kirsch: menu "Ocorrências") ────
// Registro disciplinar/de ocorrência do aluno.
model MotivoOcorrencia {
  id    String  @id @default(uuid())
  nome  String
  ativo Boolean @default(true)

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  ocorrencias Ocorrencia[]

  @@map("motivos_ocorrencia")
}

model Ocorrencia {
  id        String           @id @default(uuid())
  alunoId   String
  aluno     Aluno            @relation(fields: [alunoId], references: [id])
  motivoId  String
  motivo    MotivoOcorrencia @relation(fields: [motivoId], references: [id])
  descricao String?          @db.Text
  data      DateTime         @db.Date
  usuarioId String?

  criadoEm DateTime @default(now())

  @@map("ocorrencias")
}

// ── Mensagens (achado do spike Kirsch: menu "Portais" — Compor Mensagens /
// Manutenção de Mensagens Enviadas). Mensagem direcionada admin/secretaria
// -> usuário específico; diferente de Aviso (mural geral pra todos).
model Mensagem {
  id             String   @id @default(uuid())
  remetenteId    String
  remetente      Usuario  @relation("MensagensEnviadas", fields: [remetenteId], references: [id])
  destinatarioId String
  destinatario   Usuario  @relation("MensagensRecebidas", fields: [destinatarioId], references: [id])
  assunto        String
  corpo          String   @db.Text
  lida           Boolean  @default(false)

  criadoEm DateTime @default(now())

  @@map("mensagens")
}

// ── Observações Financeiras (achado do spike Kirsch: menu "CReceber" —
// Observações Financeiras). Nota livre do financeiro/secretaria por aluno.
model ObservacaoFinanceira {
  id         String   @id @default(uuid())
  alunoId    String
  aluno      Aluno    @relation(fields: [alunoId], references: [id])
  observacao String   @db.Text
  data       DateTime @default(now())
  usuarioId  String?

  criadoEm DateTime @default(now())

  @@map("observacoes_financeiras")
}

// ── Ramais (catálogo institucional exibido no modal "Ramais" do BottomBar;
// gerenciado por ADMIN em Utilitários > Ramais). Leitura livre pra qualquer
// autenticado, escrita restrita a ADMIN (feito no controller, não aqui).
model Ramal {
  id     String  @id @default(uuid())
  nome   String
  setor  String?
  numero String
  ativo  Boolean @default(true)

  criadoEm    DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  @@map("ramais")
}
