// =============================================================================
// schema.prisma — FIURJ Plataforma Acadêmica
// Núcleo de Graduação · Fase 0
//
// Campos marcados com // [CENSO] são exigidos pelo Censo da Educação Superior
// (INEP) e devem existir desde o início — nunca remover.
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// ESTRUTURA ACADÊMICA
// =============================================================================

model Curso {
  id                          String   @id @default(uuid())
  nome                        String
  grau                        Grau     // [CENSO] bacharelado | licenciatura | tecnologo
  modalidade                  Modalidade // [CENSO] presencial | EAD
  codigoEmec                  String   @unique // [CENSO]
  cargaHorariaTotal           Int
  prazoIntegralizacaoSemestres Int
  status                      CursoStatus @default(ATIVO)

  criadoEm   DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  matrizesCurriculares MatrizCurricular[]
  alunos               Aluno[]
  processosSeletivos   ProcessoSeletivo[]

  @@map("cursos")
}

model MatrizCurricular {
  id          String              @id @default(uuid())
  cursoId     String
  versao      String
  anoVigencia Int
  status      MatrizStatus        @default(VIGENTE)

  criadoEm   DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  curso       Curso         @relation(fields: [cursoId], references: [id])
  disciplinas Disciplina[]
  alunos      Aluno[]

  @@unique([cursoId, versao])
  @@map("matrizes_curriculares")
}

model Disciplina {
  id                 String   @id @default(uuid())
  matrizCurricularId String
  codigo             String
  nome               String
  cargaHoraria       Int
  creditos           Int
  ementa             String?  @db.Text
  periodoSugerido    Int

  criadoEm   DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  matrizCurricular MatrizCurricular           @relation(fields: [matrizCurricularId], references: [id])
  ofertas          Oferta[]
  prerequisitos    DisciplinaPrerequisito[]   @relation("disciplina")
  dependentes      DisciplinaPrerequisito[]   @relation("prerequisito")
  equiparacoes     MateriaEquiparada[]

  @@unique([matrizCurricularId, codigo])
  @@map("disciplinas")
}

model DisciplinaPrerequisito {
  id            String @id @default(uuid())
  disciplinaId  String
  prerequisitoId String

  disciplina   Disciplina @relation("disciplina",   fields: [disciplinaId],   references: [id])
  prerequisito Disciplina @relation("prerequisito", fields: [prerequisitoId], references: [id])

  @@unique([disciplinaId, prerequisitoId])
  @@map("disciplinas_prerequisitos")
}

// =============================================================================
// PERÍODO LETIVO
// =============================================================================

model PeriodoLetivo {
  id         String              @id @default(uuid())
  ano        Int
  semestre   Semestre            // 1 ou 2
  dataInicio DateTime            @db.Date
  dataFim    DateTime            @db.Date
  status     PeriodoStatus       @default(PLANEJADO)
  semanasLetivas Int?
  diasLetivos    Int?

  criadoEm   DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  ofertas             Oferta[]
  processosSeletivos  ProcessoSeletivo[]
  contratos           ContratoMatricula[]
  eventosCalendario   EventoCalendario[]

  @@unique([ano, semestre])
  @@map("periodos_letivos")
}

model EventoCalendario {
  id              String   @id @default(uuid())
  periodoLetivoId String
  grupo           String?  // ex.: "Exames Finais", "Exames de 2a Epoca" - null para item avulso
  titulo          String   // ex.: "Inicio das Aulas", "Regime de Credito"
  dataInicio      DateTime @db.Date
  dataFim         DateTime? @db.Date
  observacoes     String?
  ordem           Int      @default(0)

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  periodoLetivo PeriodoLetivo @relation(fields: [periodoLetivoId], references: [id], onDelete: Cascade)

  @@map("eventos_calendario")
}

// =============================================================================
// OFERTA (turma)
// =============================================================================

model Oferta {
  id              String   @id @default(uuid())
  disciplinaId    String
  periodoLetivoId String
  professorId     String
  vagas           Int
  turno           Turno    // [CENSO] manha | tarde | noite | integral
  horario         String?
  sala            String?

  criadoEm   DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  disciplina    Disciplina           @relation(fields: [disciplinaId],    references: [id])
  periodoLetivo PeriodoLetivo        @relation(fields: [periodoLetivoId], references: [id])
  professor     Professor            @relation(fields: [professorId],     references: [id])
  matriculas    MatriculaDisciplina[]
  avisos        Aviso[]
  capturasProva CapturaProva[]

  @@map("ofertas")
}

// =============================================================================
// PESSOAS
// =============================================================================

model Aluno {
  id                 String          @id @default(uuid())
  cursoId            String
  matrizCurricularId String
  ra                 String          @unique  // registro acadêmico
  nome               String
  cpf                String          @unique
  dataNascimento     DateTime        @db.Date
  sexo               Sexo            // [CENSO]
  corRaca            CorRaca         // [CENSO]
  nacionalidade      String          // [CENSO]
  formaIngresso      FormaIngresso   // [CENSO]
  dataIngresso       DateTime        @db.Date // [CENSO]
  situacaoVinculo    SituacaoVinculo @default(CURSANDO) // [CENSO]
  email              String          @unique
  telefone           String?
  cep                String?
  logradouro         String?
  numero             String?
  complemento        String?
  bairro             String?
  uf                 String?         @db.Char(2)
  municipio          String?

  codigoValidacaoCarteirinha String?   @unique // código impresso/QR da carteirinha, para validação pública
  carteirinhaValidaAte       DateTime?

  criadoEm   DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  curso            Curso                @relation(fields: [cursoId],            references: [id])
  matrizCurricular MatrizCurricular     @relation(fields: [matrizCurricularId], references: [id])
  usuario          Usuario?
  matriculas       MatriculaDisciplina[]
  consentimentos   ConsentimentoLgpd[]
  requerimentos    Requerimento[]
  contratos        ContratoMatricula[]
  fichaSaude       FichaSaude?
  documentos       DocumentoAluno[]
  equiparacoes     MateriaEquiparada[]
  historicoSituacao HistoricoSituacaoVinculo[]
  protocolos       Protocolo[]
  ocorrencias      Ocorrencia[]
  observacoesFinanceiras ObservacaoFinanceira[]
  bolsas           Bolsista[]
  capturasProva    CapturaProva[]

  @@map("alunos")
}

model Professor {
  id             String          @id @default(uuid())
  nome           String
  cpf            String          @unique
  titulacao      Titulacao       // [CENSO]
  regimeTrabalho RegimeTrabalho  // [CENSO]
  corRaca        CorRaca         @default(NAO_DECLARADO) // [CENSO]
  lattes         String?
  email          String          @unique
  telefone       String?

  criadoEm   DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  usuario Usuario?
  ofertas Oferta[]
  capturasProva CapturaProva[]
  provasGeradas ProvaGerada[]
  dadosFolha DadosFolhaProfessor?

  @@map("professores")
}

// =============================================================================
// MATRÍCULA E AVALIAÇÃO
// =============================================================================

model MatriculaDisciplina {
  id            String                 @id @default(uuid())
  alunoId       String
  ofertaId      String
  status        MatriculaStatus        @default(MATRICULADO)
  isDependencia Boolean                @default(false)
  dataMatricula DateTime               @default(now()) @db.Date

  criadoEm   DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  aluno     Aluno               @relation(fields: [alunoId],   references: [id])
  oferta    Oferta              @relation(fields: [ofertaId],  references: [id])
  avaliacoes Avaliacao[]
  resultado  ResultadoDisciplina?
  registrosFrequencia RegistroFrequencia[]
  notaPauta NotaPauta?

  @@unique([alunoId, ofertaId])
  @@map("matriculas_disciplinas")
}

// ── Frequência diária (achado do spike Kirsch: Secretaria > Manutenção de
// Frequência lança presença/falta aula-a-aula, não só o total consolidado
// no fim do período) ─────────────────────────────────────────────────────
model RegistroFrequencia {
  id                    String   @id @default(uuid())
  matriculaDisciplinaId String
  matriculaDisciplina   MatriculaDisciplina @relation(fields: [matriculaDisciplinaId], references: [id])
  data                  DateTime @db.Date
  quantidadeAulas       Int
  faltas                Int
  observacao            String?

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  @@unique([matriculaDisciplinaId, data])
  @@map("registros_frequencia")
}

model Avaliacao {
  id                    String        @id @default(uuid())
  matriculaDisciplinaId String
  tipo                  AvaliacaoTipo
  nota                  Decimal       @db.Decimal(5, 2)
  peso                  Decimal       @db.Decimal(5, 2)

  criadoEm   DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  matriculaDisciplina MatriculaDisciplina @relation(fields: [matriculaDisciplinaId], references: [id])

  @@map("avaliacoes")
}

model ResultadoDisciplina {
  id                    String             @id @default(uuid())
  matriculaDisciplinaId String             @unique
  mediaFinal            Decimal            @db.Decimal(5, 2)
  faltas                Int
  frequenciaPercentual  Decimal            @db.Decimal(5, 2)
  situacao              SituacaoResultado

  criadoEm   DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  matriculaDisciplina MatriculaDisciplina @relation(fields: [matriculaDisciplinaId], references: [id])

  @@map("resultados_disciplinas")
}

// ── Pauta por semestre (achado do spike Kirsch: "Lançamento de Notas & Frequência
// por Pauta" — tela nomeada AV1-AV5 + 2ª Chamada + Recuperação. No Kirsch a tela
// tem um seletor de bimestre, mas a FIURJ trabalha por semestre (ex.: 2026/1,
// 2026/2), não por bimestre — por isso não modelamos "etapa/bimestre" aqui: é
// uma linha só por matrícula-disciplina, já naturalmente escopada ao semestre
// via PeriodoLetivo/Oferta. Regra confirmada pelo usuário (Jul/2026) como a
// fórmula de aprovação certa pra graduação (Direito/Gestão Pública), substituindo
// a suposição anterior de "só nota mínima 6.0 + média ponderada". Fórmula
// (idêntica à encontrada na tela "Configurar Fórmula Cálculo Bimestral" do
// Kirsch, aplicada aqui uma vez por semestre em vez de uma vez por bimestre):
//   F1 = (AV1+AV2+AV3+AV4 + IF(2ªChamada>0; 2ªChamada; AV5)*6) / 10
//   Média = IF(F1 < 6 AND Recuperação > F1; Recuperação; F1)
// Calculada em tempo real na API — não fica armazenada (mesmo padrão de
// CR/Integralização já usado no restante do sistema). ─────────────────────
model NotaPauta {
  id                    String @id @default(uuid())
  matriculaDisciplinaId String @unique

  av1            Decimal? @db.Decimal(4, 2)
  av2            Decimal? @db.Decimal(4, 2)
  av3            Decimal? @db.Decimal(4, 2)
  av4            Decimal? @db.Decimal(4, 2)
  av5            Decimal? @db.Decimal(4, 2)
  segundaChamada Decimal? @db.Decimal(4, 2)
  recuperacao    Decimal? @db.Decimal(4, 2)
  faltas         Int      @default(0)

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  matriculaDisciplina MatriculaDisciplina @relation(fields: [matriculaDisciplinaId], references: [id])

  @@map("notas_pauta")
}

// =============================================================================
// AUTH, AUDITORIA E LGPD
// =============================================================================

model Usuario {
  id          String        @id @default(uuid())
  email       String        @unique
  senhaHash   String
  perfil      Perfil
  mfaAtivo    Boolean       @default(false)
  mfaSegredo  String?       // TOTP secret — nunca expor via API
  status      UsuarioStatus @default(ATIVO)

  // Perfil pessoal (auto-servico via /usuarios/me)
  nome        String?
  telefone    String?
  fotoUrl     String?

  // Relações opcionais: um usuário é ou aluno ou professor (nunca os dois)
  alunoId     String?       @unique
  professorId String?       @unique

  criadoEm   DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  aluno     Aluno?     @relation(fields: [alunoId],     references: [id])
  professor Professor? @relation(fields: [professorId], references: [id])
  auditorias Auditoria[]
  avisos     Aviso[]
  mensagensEnviadas  Mensagem[] @relation("MensagensEnviadas")
  mensagensRecebidas Mensagem[] @relation("MensagensRecebidas")
  emprestimos        Emprestimo[]
  pushTokens         PushToken[]
  chamadosAbertos    ChamadoManutencao[] @relation("ChamadoManutencaoSolicitante")
  chamadosAtendidos  ChamadoManutencao[] @relation("ChamadoManutencaoResponsavel")

  @@map("usuarios")
}

model Auditoria {
  id          String   @id @default(uuid())
  usuarioId   String?  // null = ação de sistema
  acao        String   // CREATE | UPDATE | DELETE | LOGIN | LOGOUT | etc.
  entidade    String   // nome da tabela/entidade
  entidadeId  String?  // uuid do registro afetado
  dadosAntes  Json?
  dadosDepois Json?
  ip          String?
  userAgent   String?
  criadoEm    DateTime @default(now())

  usuario Usuario? @relation(fields: [usuarioId], references: [id])

  @@index([entidade, entidadeId])
  @@index([usuarioId])
  @@index([criadoEm])
  @@map("auditorias")
}

// Matriz de permissoes de tela por perfil -- controla quais paginas do
// dashboard aparecem no menu (sidebar/Barra Rapida/BottomBar) pra cada
// perfil. Ausencia de registro pra um (perfil, chaveTela) = habilitada por
// padrao (default liberado); so grava explicitamente o que foi alternado.
// Gerenciada exclusivamente pela conta admin@fiurj.edu.br (ver
// AdminMasterGuard) -- nao pelo perfil ADMIN em geral.
model PermissaoTela {
  id           String   @id @default(uuid())
  perfil       Perfil
  chaveTela    String   // chave estavel definida em telas-sistema.ts (backend) / telas-sistema.ts (frontend)
  habilitada   Boolean  @default(true)
  atualizadoEm DateTime @updatedAt

  @@unique([perfil, chaveTela])
  @@map("permissoes_tela")
}

model ConsentimentoLgpd {
  id          String   @id @default(uuid())
  alunoId     String
  finalidade  String   // ex: "comunicacao_marketing", "compartilhamento_parceiros"
  concedido   Boolean
  data        DateTime @default(now())
  ip          String?

  aluno Aluno @relation(fields: [alunoId], references: [id])

  @@map("consentimentos_lgpd")
}

// =============================================================================
// ENUMS
// =============================================================================

// --- Censo ---
// Graus de graduação (BACHARELADO/LICENCIATURA/TECNOLOGO) alimentam o Censo
// da Educação Superior (INEP) -- nunca remover. Os 4 valores abaixo cobrem
// pós-graduação (lato sensu / stricto sensu), que é reportada num censo
// separado (Censo da Pós-Graduação) -- adicionados pra podermos cadastrar os
// cursos de mestrado/doutorado/pós-doutorado (UAL/UPT/USAL) e a
// especialização (FIURJ) no mesmo model Curso, já que a plataforma inteira
// (Aluno, Oferta, ProcessoSeletivo etc.) já gira em torno de um Curso único.
enum Grau {
  BACHARELADO
  LICENCIATURA
  TECNOLOGO
  ESPECIALIZACAO
  MESTRADO
  DOUTORADO
  POS_DOUTORADO
}

enum Modalidade {
  PRESENCIAL
  EAD
  SEMIPRESENCIAL
}

enum Turno {
  MANHA
  TARDE
  NOITE
  INTEGRAL
}

enum Sexo {
  MASCULINO
  FEMININO
  NAO_DECLARADO
}

enum CorRaca {
  BRANCA
  PRETA
  PARDA
  AMARELA
  INDIGENA
  NAO_DECLARADO
}

enum FormaIngresso {
  VESTIBULAR
  ENEM
  TRANSFERENCIA_EXTERNA
  TRANSFERENCIA_INTERNA
  PORTADOR_DIPLOMA
  CONVENIO
  OUTRO
}

enum SituacaoVinculo {
  CURSANDO
  TRANCADO
  FORMADO
  EVADIDO
  TRANSFERIDO_OUT
  FALECIDO
}

enum Titulacao {
  GRADUADO
  ESPECIALISTA
  MESTRE
  DOUTOR
  POS_DOUTOR
}

enum RegimeTrabalho {
  HORISTA
  PARCIAL   // 20h/semana
  INTEGRAL  // 40h/semana
}

// --- Status internos ---
enum CursoStatus {
  ATIVO
  ENCERRADO
}

enum MatrizStatus {
  VIGENTE
  ENCERRADA
}

enum Semestre {
  S1
  S2
}

enum PeriodoStatus {
  PLANEJADO
  EM_ANDAMENTO
  ENCERRADO
}

enum MatriculaStatus {
  MATRICULADO
  PENDENTE_EXAME  // frequência OK, nota < 6.0 — aguardando exame final
  APROVADO
  REPROVADO
  DEPENDENCIA
  TRANCADO
  CANCELADO
}

enum AvaliacaoTipo {
  PROVA
  TRABALHO
  SEMINARIO
  EXAME_FINAL
  OUTRO
}

enum SituacaoResultado {
  APROVADO
  REPROVADO_NOTA
  REPROVADO_FALTA
  REPROVADO_NOTA_E_FALTA
}

enum Perfil {
  MASTER
  ADMIN
  SECRETARIA
  FINANCEIRO
  PROFESSOR
  ALUNO
  SUPORTE
}

enum UsuarioStatus {
  ATIVO
  INATIVO
  BLOQUEADO
}

// ── Fase 5: Ingresso / Processo Seletivo ──────────────────────────────────────

model ProcessoSeletivo {
  id               String         @id @default(uuid())
  nome             String
  tipo             TipoProcesso
  cursoId          String
  curso            Curso          @relation(fields: [cursoId], references: [id])
  periodoLetivoId  String
  periodoLetivo    PeriodoLetivo  @relation(fields: [periodoLetivoId], references: [id])
  vagas            Int
  dataAbertura     DateTime
  dataEncerramento DateTime
  status           StatusProcesso @default(ABERTO)
  inscricoes       Inscricao[]
  criadoEm         DateTime       @default(now())
  atualizadoEm     DateTime       @updatedAt

  @@map("processos_seletivos")
}

model Candidato {
  id             String      @id @default(uuid())
  nome           String
  cpf            String      @unique
  email          String
  telefone       String?
  dataNascimento DateTime
  sexo           String
  corRaca        String?
  nacionalidade  String      @default("BRASILEIRA")
  inscricoes     Inscricao[]
  criadoEm       DateTime    @default(now())
  atualizadoEm   DateTime    @updatedAt

  @@map("candidatos")
}

model Inscricao {
  id                 String           @id @default(uuid())
  candidatoId        String
  candidato          Candidato        @relation(fields: [candidatoId], references: [id])
  processoSeletivoId String
  processoSeletivo   ProcessoSeletivo @relation(fields: [processoSeletivoId], references: [id])
  status             StatusInscricao  @default(INSCRITO)
  notaEnem           Decimal?
  documentosOk       Boolean          @default(false)
  observacoes        String?
  alunoId            String?          // preenchido ao converter para Aluno
  criadoEm           DateTime         @default(now())
  atualizadoEm       DateTime         @updatedAt

  @@unique([candidatoId, processoSeletivoId])
  @@map("inscricoes")
}

enum TipoProcesso {
  VESTIBULAR
  ENEM
  SEGUNDA_GRADUACAO
  TRANSFERENCIA_EXTERNA
  TRANSFERENCIA_INTERNA
}

enum StatusProcesso {
  ABERTO
  ENCERRADO
  CANCELADO
}


enum StatusInscricao {
  INSCRITO
  EM_ANALISE
  APROVADO
  REPROVADO
  MATRICULADO
  DESISTENTE
}

// ── Fase 7: Secretaria / Requerimentos ───────────────────────────────────────

model Requerimento {
  id           String              @id @default(uuid())
  alunoId      String
  aluno        Aluno               @relation(fields: [alunoId], references: [id])
  tipo         TipoRequerimento
  descricao    String?             @db.Text
  status       StatusRequerimento  @default(ABERTO)
  resposta     String?             @db.Text
  criadoEm     DateTime            @default(now())
  atualizadoEm DateTime            @updatedAt

  @@map("requerimentos")
}

enum TipoRequerimento {
  DECLARACAO_MATRICULA
  HISTORICO_OFICIAL
  TRANCAMENTO
  CANCELAMENTO
  REVISAO_NOTA
  APROVEITAMENTO_DISCIPLINA
  COLACAO_GRAU
  OUTRO
}

enum StatusRequerimento {
  ABERTO
  EM_ANALISE
  DEFERIDO
  INDEFERIDO
  CANCELADO
}

// ── Financeiro ──────────────────────────────────────────────────────────────

model ContratoMatricula {
  id              String         @id @default(uuid())
  alunoId         String
  aluno           Aluno          @relation(fields: [alunoId], references: [id])
  periodoLetivoId String
  periodoLetivo   PeriodoLetivo  @relation(fields: [periodoLetivoId], references: [id])
  valorTotal      Decimal        @db.Decimal(10, 2)
  numeroParcelas  Int
  diaVencimento   Int            // 1–28
  status          StatusContrato @default(ATIVO)
  observacoes     String?        @db.Text
  criadoEm       DateTime       @default(now())
  atualizadoEm   DateTime       @updatedAt

  parcelas Parcela[]

  @@map("contratos_matricula")
}

model Parcela {
  id             String        @id @default(uuid())
  contratoId     String
  contrato       ContratoMatricula @relation(fields: [contratoId], references: [id])
  numero         Int
  valor          Decimal       @db.Decimal(10, 2)
  dataVencimento DateTime      @db.Date
  dataPagamento  DateTime?     @db.Date
  valorPago      Decimal?      @db.Decimal(10, 2)
  status         StatusParcela @default(PENDENTE)
  formaPagamento String?
  observacoes    String?
  criadoEm      DateTime      @default(now())
  atualizadoEm  DateTime      @updatedAt

  boleto Boleto?

  @@map("parcelas")
}

enum StatusContrato {
  ATIVO
  SUSPENSO
  CANCELADO
  ENCERRADO
}

enum StatusParcela {
  PENDENTE
  PAGO
  VENCIDO
  CANCELADO
}

// ── Avisos ──────────────────────────────────────────────────────
// ofertaId nullable = "aviso de turma" (Jul/2026, Menu Docente): quando
// preenchido, o aviso fica restrito aos alunos matriculados nessa oferta em
// vez de aparecer no mural geral pra todo mundo — ver AvisoService.findAll()
// e DocenteService.criarAvisoTurma(). Aviso geral (ofertaId null) continua
// funcionando exatamente como antes, sem nenhuma mudança de comportamento.
model Aviso {
  id         String   @id @default(uuid())
  titulo     String
  texto      String
  tag        TagAviso @default(GERAL)
  autorNome  String
  autorId    String?
  ofertaId   String?
  usuario    Usuario? @relation(fields: [autorId], references: [id])
  oferta     Oferta?  @relation(fields: [ofertaId], references: [id], onDelete: SetNull)
  criadoEm  DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  @@map("avisos")
}

enum TagAviso {
  GERAL
  IMPORTANTE
  APENAS_EQUIPE
}

// Captura de Prova (Jul/2026, Menu Docente): professor fotografa/envia a
// prova física corrigida do aluno como registro digital — mesmo padrão de
// upload do DocumentoAluno (Secretaria), só que iniciado pelo professor e
// escopado a uma oferta/disciplina específica em vez de "documento geral".
model CapturaProva {
  id          String   @id @default(uuid())
  alunoId     String
  ofertaId    String
  professorId String
  nomeArquivo String
  url         String
  tamanho     Int
  observacoes String?
  criadoEm    DateTime @default(now())

  aluno     Aluno     @relation(fields: [alunoId], references: [id], onDelete: Cascade)
  oferta    Oferta    @relation(fields: [ofertaId], references: [id], onDelete: Cascade)
  professor Professor @relation(fields: [professorId], references: [id])

  @@map("capturas_prova")
}

// Gerador de Prova (Jul/2026) — professor monta cabeçalho + questões (múltipla
// escolha ou dissertativa) e o sistema gera um documento imprimível. Sem tabela
// própria de questão: `questoes` guarda um array JSON (mesmo raciocínio já usado
// em `ConfiguracaoVisual.galeriaPublicidade` — poucas dezenas de itens no
// máximo, sempre lidas/escritas como o array inteiro, nunca uma questão
// individual isolada, não justifica uma tabela relacional própria). Visível
// tanto pro professor que gerou (imprimir de novo) quanto pra Secretaria
// (listagem "Provas Geradas", só leitura/impressão).
model ProvaGerada {
  id          String   @id @default(uuid())
  professorId String
  tipoProva   String // AV1..AV5, RECUPERACAO, SEGUNDA_CHAMADA — texto livre de cabeçalho, não enum
  curso       String
  disciplina  String
  turma       String
  data        DateTime @db.Date
  observacoes String   @db.Text
  questoes    Json // QuestaoProva[] — ver DTO em prova-gerada/dto
  criadoEm    DateTime @default(now())

  professor Professor @relation(fields: [professorId], references: [id])

  @@map("provas_geradas")
}

// Token de push notification (Expo) do dispositivo do usuário — usado hoje
// só pelo app mobile do aluno, pra receber "Aviso para Turma" enviado pelo
// professor. Um token é ligado ao dispositivo, não a uma sessão: se o mesmo
// token aparecer de novo (reinstalação, outro usuário no mesmo aparelho), o
// upsert por token substitui o dono anterior.
model PushToken {
  id         String   @id @default(uuid())
  usuarioId  String
  token      String   @unique
  plataforma String?
  criadoEm   DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@map("push_tokens")
}

// ── Ficha de Saúde ──────────────────────────────────────────────
// Dado sensível (LGPD, art. 5º II) — acesso restrito a ADMIN/SECRETARIA,
// nunca exposto a PROFESSOR/ALUNO via API.
model FichaSaude {
  id                        String   @id @default(uuid())
  alunoId                   String   @unique
  aluno                     Aluno    @relation(fields: [alunoId], references: [id])
  tipoSanguineo             String?
  alergias                  String?  @db.Text
  medicamentosUso           String?  @db.Text
  deficiencia               String?  // texto livre; ex.: "Auditiva, Visual" (achado da Kirsch)
  planoSaude                String?
  contatoEmergenciaNome     String?
  contatoEmergenciaTelefone String?
  observacoes               String?  @db.Text

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  @@map("fichas_saude")
}

// ── Contas Bancárias ────────────────────────────────────────────
// Cadastro interno de contas da instituição. Campos `cnab*`/`sequencialRemessa`
// (Jul/2026) habilitam a conta pra emissão/registro de boleto via arquivo CNAB
// direto com o banco (substituiu o plano anterior de integração via Asaas —
// ver seção "Módulo Financeiro — Integração Bancária CNAB" do CLAUDE.md).
// Não é conta de aluno/fornecedor.
model ContaBancaria {
  id             String            @id @default(uuid())
  banco          String
  agencia        String
  numeroConta    String
  tipoConta      TipoContaBancaria @default(CORRENTE)
  titular        String
  cnpjCpfTitular String?
  saldoInicial   Decimal           @default(0) @db.Decimal(12, 2)
  ativa          Boolean           @default(true)
  observacoes    String?           @db.Text

  // ── CNAB (opcionais — só preenchidos quando cnabHabilitado = true) ──
  cnabHabilitado      Boolean    @default(false)
  codigoBancoFebraban String?    // ex.: "341" Itaú, "422" Safra, "033" Santander, "104" Caixa
  codigoCedente        String?   // convênio / código de beneficiário junto ao banco
  carteira             String?
  variacaoCarteira     String?
  layoutCnab           LayoutCnab?
  sequencialRemessa    Int        @default(0) // incrementado a cada remessa gerada por esta conta

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  boletos   Boleto[]
  remessas  RemessaCnab[]
  retornos  RetornoCnab[]

  @@map("contas_bancarias")
}

enum TipoContaBancaria {
  CORRENTE
  POUPANCA
  PAGAMENTO
}

// ── Digitalização de Documentos ────────────────────────────────
model DocumentoAluno {
  id          String   @id @default(uuid())
  alunoId     String
  aluno       Aluno    @relation(fields: [alunoId], references: [id])
  tipo        String   // ex.: RG, CPF, Comprovante de Residência, Histórico Escolar, Diploma, Outro
  nomeArquivo String
  url         String
  tamanho     Int      // bytes

  criadoEm DateTime @default(now())

  @@map("documentos_aluno")
}

// ── Unidades ────────────────────────────────────────────────────
// Catálogo simples de referência (não é multi-tenancy — os dados continuam
// todos numa base única; achado da Kirsch confirmou 2 unidades cadastradas:
// FIURJ Campos Centro e UAL Lisboa).
model Unidade {
  id     String  @id @default(uuid())
  nome   String
  cidade String?
  uf     String? @db.Char(2)
  ativa  Boolean @default(true)

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  @@map("unidades")
}

// ── Receitas (catálogo financeiro) ───────────────────────────────
model CategoriaReceita {
  id        String  @id @default(uuid())
  nome      String
  descricao String?
  ativa     Boolean @default(true)

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  @@map("categorias_receita")
}

// ── Matérias Equiparadas ─────────────────────────────────────────
// Registro de aproveitamento de disciplina cursada em outra instituição/
// curso (transferência, portador de diploma). Documental — não gera
// MatriculaDisciplina/Oferta automaticamente; não entra no cálculo de CR.
model MateriaEquiparada {
  id                 String     @id @default(uuid())
  alunoId            String
  aluno              Aluno      @relation(fields: [alunoId], references: [id])
  disciplinaId       String
  disciplina         Disciplina @relation(fields: [disciplinaId], references: [id])
  instituicaoOrigem  String
  disciplinaOrigem   String
  cargaHorariaOrigem Int?
  dataAprovacao      DateTime   @db.Date
  observacoes        String?    @db.Text

  criadoEm DateTime @default(now())

  @@map("materias_equiparadas")
}

// ── Histórico de Mudança de Situação de Vínculo ─────────────────
model HistoricoSituacaoVinculo {
  id               String          @id @default(uuid())
  alunoId          String
  aluno            Aluno           @relation(fields: [alunoId], references: [id])
  situacaoAnterior SituacaoVinculo
  situacaoNova     SituacaoVinculo
  motivo           String?
  data             DateTime        @db.Date
  usuarioId        String?

  criadoEm DateTime @default(now())

  @@map("historico_situacao_vinculo")
}

// ── Protocolo (achado do spike Kirsch: menu "Protocolo") ────────
// Registro genérico de protocolo administrativo — mais amplo que Requerimento
// (que tem tipo fixo); Protocolo pode ou não estar ligado a um aluno.
model TipoProtocolo {
  id    String  @id @default(uuid())
  nome  String
  ativo Boolean @default(true)

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  protocolos Protocolo[]

  @@map("tipos_protocolo")
}

model Protocolo {
  id                String          @id @default(uuid())
  numero            String          @unique
  tipoId            String
  tipo              TipoProtocolo   @relation(fields: [tipoId], references: [id])
  alunoId           String?
  aluno             Aluno?          @relation(fields: [alunoId], references: [id])
  assunto           String
  descricao         String?         @db.Text
  status            StatusProtocolo @default(ABERTO)
  dataAbertura       DateTime       @default(now())
  dataConclusao      DateTime?
  usuarioAberturaId String?

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  @@map("protocolos")
}

enum StatusProtocolo {
  ABERTO
  EM_ANDAMENTO
  CONCLUIDO
  CANCELADO
}

// ── Suporte / Chamados de Manutenção (Jul/2026) ──────────────────
// Aberto por QUALQUER perfil autenticado (inclusive ALUNO); gerenciado por
// ADMIN/SECRETARIA/SUPORTE. Mesmo padrão de numeração sequencial por ano
// do Protocolo (CM20260001...), status simples sem máquina de estados rígida
// (só a coluna `status`, sem tabela de timeline/comentários — decisão
// deliberada, ver CLAUDE.md).
model TipoChamadoManutencao {
  id    String  @id @default(uuid())
  nome  String
  ativo Boolean @default(true)

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  chamados ChamadoManutencao[]

  @@map("tipos_chamado_manutencao")
}

model ChamadoManutencao {
  id            String                  @id @default(uuid())
  numero        String                  @unique
  tipoId        String
  tipo          TipoChamadoManutencao   @relation(fields: [tipoId], references: [id])
  local         String
  prioridade    PrioridadeChamado       @default(MEDIA)
  titulo        String
  descricao     String?                 @db.Text
  status        StatusChamadoManutencao @default(ABERTO)
  solicitanteId String
  solicitante   Usuario                 @relation("ChamadoManutencaoSolicitante", fields: [solicitanteId], references: [id])
  responsavelId String?
  responsavel   Usuario?                @relation("ChamadoManutencaoResponsavel", fields: [responsavelId], references: [id])
  dataAbertura  DateTime                @default(now())
  dataConclusao DateTime?

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  @@map("chamados_manutencao")
}

enum PrioridadeChamado {
  BAIXA
  MEDIA
  ALTA
  URGENTE
}

enum StatusChamadoManutencao {
  ABERTO
  EM_ANDAMENTO
  CONCLUIDO
  CANCELADO
}

// ── Ocorrências (achado do spike Kirsch: menu "Ocorrências") ────
// Registro disciplinar/de ocorrência do aluno.
model MotivoOcorrencia {
  id    String  @id @default(uuid())
  nome  String
  ativo Boolean @default(true)

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  ocorrencias Ocorrencia[]

  @@map("motivos_ocorrencia")
}

model Ocorrencia {
  id        String           @id @default(uuid())
  alunoId   String
  aluno     Aluno            @relation(fields: [alunoId], references: [id])
  motivoId  String
  motivo    MotivoOcorrencia @relation(fields: [motivoId], references: [id])
  descricao String?          @db.Text
  data      DateTime         @db.Date
  usuarioId String?

  criadoEm DateTime @default(now())

  @@map("ocorrencias")
}

// ── Mensagens (achado do spike Kirsch: menu "Portais" — Compor Mensagens /
// Manutenção de Mensagens Enviadas). Mensagem direcionada admin/secretaria
// -> usuário específico; diferente de Aviso (mural geral pra todos).
model Mensagem {
  id             String   @id @default(uuid())
  remetenteId    String
  remetente      Usuario  @relation("MensagensEnviadas", fields: [remetenteId], references: [id])
  destinatarioId String
  destinatario   Usuario  @relation("MensagensRecebidas", fields: [destinatarioId], references: [id])
  assunto        String
  corpo          String   @db.Text
  lida           Boolean  @default(false)

  criadoEm DateTime @default(now())

  @@map("mensagens")
}

// ── Observações Financeiras (achado do spike Kirsch: menu "CReceber" —
// Observações Financeiras). Nota livre do financeiro/secretaria por aluno.
model ObservacaoFinanceira {
  id         String   @id @default(uuid())
  alunoId    String
  aluno      Aluno    @relation(fields: [alunoId], references: [id])
  observacao String   @db.Text
  data       DateTime @default(now())
  usuarioId  String?

  criadoEm DateTime @default(now())

  @@map("observacoes_financeiras")
}

// ── Ramais (catálogo institucional exibido no modal "Ramais" do BottomBar;
// gerenciado por ADMIN em Utilitários > Ramais). Leitura livre pra qualquer
// autenticado, escrita restrita a ADMIN (feito no controller, não aqui).
model Ramal {
  id     String  @id @default(uuid())
  nome   String
  setor  String?
  numero String
  ativo  Boolean @default(true)

  criadoEm    DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  @@map("ramais")
}

// ── Motivos de Transferência & Cancelamento (achado do spike Kirsch: catálogo
// pré-definido pra padronizar o campo `motivo` de Transferência de Turma e
// Mudança de Situação — hoje texto livre nesses dois fluxos; o catálogo entra
// como sugestão via <datalist>, sem forçar obrigatoriedade).
model MotivoTransferenciaCancelamento {
  id    String  @id @default(uuid())
  nome  String
  ativo Boolean @default(true)

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  @@map("motivos_transferencia_cancelamento")
}

// ── Bolsistas (Kirsch: Financeiro > Cadastro de Bolsistas / Relatórios >
// Listagem de Alunos Bolsistas). 1-N com Aluno — permite histórico de bolsas
// ao longo do curso, não só um registro fixo.
model Bolsista {
  id          String    @id @default(uuid())
  alunoId     String
  aluno       Aluno     @relation(fields: [alunoId], references: [id])
  tipoBolsa   String
  percentual  Decimal   @db.Decimal(5, 2)
  dataInicio  DateTime  @db.Date
  dataFim     DateTime? @db.Date
  ativo       Boolean   @default(true)
  observacoes String?   @db.Text

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  @@map("bolsistas")
}

// ── Configuração Visual (branding) — nome, logo, símbolo e cores da
// instituição, editáveis pelo ADMIN numa tela própria, sem alterar código.
// Viabiliza reaproveitar esta plataforma pra outra instituição só
// reconfigurando aqui (a arquitetura segue single-tenant — ver seção 5 da
// especificação — então "outra instituição" = outro deploy inteiro, não
// multi-tenant dentro deste). Singleton: sempre uma única linha, id fixo
// "default" (ver migração — já insere a linha inicial com os valores atuais
// da FIURJ como default, pra não quebrar o deploy existente).
model ConfiguracaoVisual {
  id              String  @id @default("default")
  nomeInstituicao String  @default("FIURJ")
  nomeCompleto    String  @default("FIURJ — Faculdade Instituto Universitário do Rio de Janeiro")
  logoUrl         String?
  logoBrancaUrl   String?
  simboloUrl      String?
  corPrimaria     String  @default("#1C3A6B")
  corSecundaria   String  @default("#C8102E")
  // Galeria de imagens de publicidade exibida no /dashboard do perfil ALUNO
  // (no lugar dos 3 boxes de estatísticas). Array de
  // { id, url, ordem, ativa, link? } guardado como JSON — poucas dezenas de
  // itens no máximo, não justifica uma tabela própria. Gerenciada em
  // /dashboard/admin/visual (mesma tela de Identidade Visual).
  galeriaPublicidade Json @default("[]")

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  @@map("configuracao_visual")
}

// ── Biblioteca (feature nova, sem equivalente mapeado no Kirsch) — acervo de
// livros (catálogo + exemplares físicos, já que um título pode ter várias
// cópias com status independentes) e equipamentos (computadores/notebooks/
// tablets), ambos emprestáveis pra alunos e professores via `Emprestimo`.
enum StatusItemBiblioteca {
  DISPONIVEL
  EMPRESTADO
  MANUTENCAO
  EXTRAVIADO
  BAIXADO
}

enum TipoEquipamento {
  COMPUTADOR
  NOTEBOOK
  TABLET
  OUTRO
}

enum TipoItemEmprestimo {
  LIVRO
  EQUIPAMENTO
}

enum StatusEmprestimo {
  EM_ANDAMENTO
  DEVOLVIDO
  PERDIDO
}

model Livro {
  id            String  @id @default(uuid())
  titulo        String
  autor         String
  editora       String?
  isbn          String?
  categoria     String?
  anoPublicacao Int?
  // Classificação bibliotecária (CDD = Classificação Decimal de Dewey, ex:
  // "305.8"; cutter = notação de Cutter-Sanborn, ex: "G298i") -- juntos
  // formam a "chamada" impressa na lombada/etiqueta do livro. Pertencem ao
  // TÍTULO (não ao exemplar): todas as cópias da mesma obra compartilham a
  // mesma classificação, só o número do exemplar e o tombamento mudam por
  // cópia (ver ExemplarLivro.numeroExemplar/codigoTombamento).
  cdd    String?
  cutter String?
  // Edição (ex: "24.ed", "8.ed.atu"), texto livre -- fonte real (docx da
  // biblioteca de Direito) tem formatos inconsistentes o bastante (com/sem
  // ponto, "atu"/"rev" grudado) pra não valer a pena tentar estruturar num
  // formato mais rígido.
  edicao String?

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  exemplares ExemplarLivro[]

  @@map("livros")
}

// Separado de Livro de propósito: um título pode ter N cópias físicas, cada
// uma com seu próprio status de disponibilidade/empréstimo.
model ExemplarLivro {
  id               String               @id @default(uuid())
  livroId          String
  livro            Livro                @relation(fields: [livroId], references: [id], onDelete: Cascade)
  codigoTombamento String               @unique
  localizacao      String?
  status           StatusItemBiblioteca @default(DISPONIVEL)
  // "ex.N" na etiqueta -- número sequencial da cópia dentro do MESMO livro
  // (não é o tombamento, que é único globalmente). Atribuído automaticamente
  // pelo backend ao cadastrar o exemplar (ver LivroService.addExemplar).
  numeroExemplar   Int?

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  emprestimos Emprestimo[]

  @@map("exemplares_livro")
}

model Equipamento {
  id          String               @id @default(uuid())
  patrimonio  String               @unique
  tipo        TipoEquipamento
  modelo      String
  numeroSerie String?
  status      StatusItemBiblioteca @default(DISPONIVEL)
  observacoes String?              @db.Text

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  emprestimos Emprestimo[]

  @@map("equipamentos_biblioteca")
}

// Modelo único pra empréstimo de livro OU equipamento (discriminado por
// `tipoItem`, com exatamente um dos dois FKs opcionais preenchido) — evita
// duplicar a tela/relatório de "meus empréstimos" e de atrasados em duas
// tabelas paralelas. `usuario` é quem toma o item emprestado (aluno ou
// professor, ambos são Usuario); `registradoPorId` é só um registro de quem
// operou no balcão (mesmo padrão leve de Ocorrencia.usuarioId/
// Protocolo.usuarioAberturaId — sem relação formal, só auditoria).
model Emprestimo {
  id                    String              @id @default(uuid())
  tipoItem              TipoItemEmprestimo
  exemplarLivroId       String?
  exemplarLivro         ExemplarLivro?      @relation(fields: [exemplarLivroId], references: [id])
  equipamentoId         String?
  equipamento           Equipamento?        @relation(fields: [equipamentoId], references: [id])
  usuarioId             String
  usuario               Usuario             @relation(fields: [usuarioId], references: [id])
  dataEmprestimo        DateTime            @default(now())
  dataPrevistaDevolucao DateTime
  dataDevolucao         DateTime?
  status                StatusEmprestimo    @default(EM_ANDAMENTO)
  observacoes           String?             @db.Text
  // Dois flags independentes (não são mutuamente exclusivos): uso
  // institucional exige observações preenchidas (justificativa/finalidade);
  // uso por aluno força devolução no mesmo dia, até o fechamento da
  // instituição (22:20) — ver EmprestimoService.fechamentoHoje().
  usoInstitucional      Boolean             @default(false)
  usoPorAluno           Boolean             @default(false)
  registradoPorId       String?

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  @@map("emprestimos_biblioteca")
}

// =============================================================================
// FINANCEIRO — CNAB (boleto, remessa, retorno, baixa automática) — Jul/2026
//
// Substitui o plano anterior de integração via Asaas (Fase 6b). Cada `Boleto`
// representa uma `Parcela` já existente (1-1 opcional — nem toda parcela
// precisa de boleto, pagamento manual continua funcionando como antes).
// `Boleto.status` guarda só o estado consolidado de ciclo de vida que o resto
// do sistema precisa entender; o histórico cru de cada ocorrência lida do
// arquivo de retorno do banco fica em `OcorrenciaCnab`, pra rastreabilidade
// completa sem precisar modelar os dezenas de códigos de ocorrência de cada
// banco como enum. Interface única de banco (`CnabBankAdapter`, em
// backend/src/financial/cnab/bancos/) + um adapter por banco — só o Itaú
// (CNAB 400) está implementado nesta rodada; Safra/Santander/Caixa (CNAB 240)
// ficam como stub até serem homologados.
// =============================================================================

enum BancoCnab {
  ITAU
  SAFRA
  SANTANDER
  CAIXA
}

enum LayoutCnab {
  CNAB400
  CNAB240
}

enum StatusBoleto {
  EMITIDO         // criado no sistema, ainda não enviado numa remessa
  ENVIADO_REMESSA // incluído numa remessa, aguardando confirmação do banco
  REGISTRADO      // banco confirmou o registro
  LIQUIDADO       // pago/baixado
  REJEITADO       // banco rejeitou o registro
  CANCELADO       // baixa solicitada / cancelamento processado
  PROTESTADO
}

enum StatusRemessa {
  GERADA
  ENVIADA
}

enum StatusOcorrenciaCnab {
  PROCESSADA
  NAO_LOCALIZADO
  ERRO
}

model Boleto {
  id             String   @id @default(uuid())
  parcelaId      String   @unique
  parcela        Parcela  @relation(fields: [parcelaId], references: [id])
  contaBancariaId String
  contaBancaria  ContaBancaria @relation(fields: [contaBancariaId], references: [id])
  banco          BancoCnab

  nossoNumero    String   @unique
  carteira       String
  especie        String   @default("DM")
  status         StatusBoleto @default(EMITIDO)

  linhaDigitavel String
  codigoBarras   String

  dataRegistro   DateTime?
  dataLiquidacao DateTime?
  valorPago      Decimal? @db.Decimal(10, 2)
  valorJuros     Decimal? @db.Decimal(10, 2)
  valorMulta     Decimal? @db.Decimal(10, 2)
  valorDesconto  Decimal? @db.Decimal(10, 2)

  ultimaOcorrenciaCodigo      String?
  ultimaOcorrenciaDescricao   String?
  motivoRejeicao              String?

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  itensRemessa  RemessaCnabItem[]
  ocorrencias   OcorrenciaCnab[]

  @@map("boletos")
}

model RemessaCnab {
  id                  String        @id @default(uuid())
  contaBancariaId     String
  contaBancaria       ContaBancaria @relation(fields: [contaBancariaId], references: [id])
  banco               BancoCnab
  layout              LayoutCnab
  sequencial          Int
  dataGeracao         DateTime      @default(now())
  quantidadeRegistros Int
  valorTotal          Decimal       @db.Decimal(12, 2)
  status              StatusRemessa @default(GERADA)
  arquivoNome         String
  arquivoUrl          String
  usuarioId           String

  itens RemessaCnabItem[]

  @@map("remessas_cnab")
}

// Join Remessa x Boleto — uma linha por boleto incluído numa remessa; um
// boleto pode aparecer em mais de uma remessa se for reenviado após rejeição.
model RemessaCnabItem {
  id        String      @id @default(uuid())
  remessaId String
  remessa   RemessaCnab @relation(fields: [remessaId], references: [id])
  boletoId  String
  boleto    Boleto      @relation(fields: [boletoId], references: [id])

  criadoEm DateTime @default(now())

  @@map("remessas_cnab_itens")
}

model RetornoCnab {
  id                    String        @id @default(uuid())
  contaBancariaId       String
  contaBancaria         ContaBancaria @relation(fields: [contaBancariaId], references: [id])
  banco                 BancoCnab
  nomeArquivoOriginal   String
  dataImportacao        DateTime      @default(now())
  quantidadeRegistros   Int
  valorTotalOcorrencias Decimal       @db.Decimal(12, 2)
  usuarioId             String

  ocorrencias OcorrenciaCnab[]

  @@map("retornos_cnab")
}

model OcorrenciaCnab {
  id                String      @id @default(uuid())
  retornoId         String
  retorno           RetornoCnab @relation(fields: [retornoId], references: [id])
  boletoId          String?
  boleto            Boleto?     @relation(fields: [boletoId], references: [id])
  nossoNumero       String      // valor cru lido do arquivo — útil pra investigar não-localizados

  codigoOcorrencia    String
  descricaoOcorrencia String
  dataOcorrencia      DateTime

  valorPago     Decimal? @db.Decimal(10, 2)
  valorJuros    Decimal? @db.Decimal(10, 2)
  valorMulta    Decimal? @db.Decimal(10, 2)
  valorDesconto Decimal? @db.Decimal(10, 2)

  statusProcessamento StatusOcorrenciaCnab
  mensagemErro        String?

  criadoEm DateTime @default(now())

  @@map("ocorrencias_cnab")
}

// =============================================================================
// CPAGAR — Contas a Pagar (folha de pagamento, prestadores, acordos, gastos) —
// Jul/2026
//
// Módulo novo, sem equivalente mapeado no Kirsch (o spike de exploração nunca
// encontrou um menu de RH/folha/contas a pagar lá). Cobre o lado inverso do
// CReceber: aqui é a FIURJ que paga terceiros (professor, colaborador,
// prestador de serviço, fornecedor).
//
// ⚠️ RISCO MAIOR que o módulo CNAB — aqui o erro é calcular errado o salário
// líquido de uma pessoa real e/ou informar valor errado ao Fisco, não só um
// arquivo rejeitado pelo banco. Por isso as tabelas de INSS/IRRF são cadastro
// editável (TabelaInss/TabelaIrrf), não constante no código — precisam ser
// conferidas/atualizadas por um contador antes de qualquer folha real. Ver
// aviso completo no plano de implementação e nos comentários de
// backend/src/cpagar/calculo-folha.util.ts.
// =============================================================================

enum TipoVinculo {
  PRESTADOR_SERVICO
  COLABORADOR
}

enum StatusFolha {
  ABERTA
  FECHADA
  PAGA
}

enum TipoLancamentoFolha {
  PROVENTO
  DESCONTO
}

enum StatusAcordoPagar {
  ATIVO
  CONCLUIDO
  CANCELADO
}

enum StatusParcelaPagar {
  PENDENTE
  PAGO
  VENCIDO
  CANCELADO
}

// Extensão 1-1 opcional do Professor já existente — dados de pagamento não
// entram no model acadêmico (mesmo padrão de FichaSaude/Boleto: extensão à
// parte pra não poluir um model com campos de outro domínio).
model DadosFolhaProfessor {
  id                String    @id @default(uuid())
  professorId       String    @unique
  professor         Professor @relation(fields: [professorId], references: [id])
  salarioBase       Decimal   @db.Decimal(10, 2)
  numeroDependentes Int       @default(0)
  dataAdmissao      DateTime  @db.Date
  dataDemissao      DateTime? @db.Date
  ativo             Boolean   @default(true)

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  itensFolha ItemFolha[]

  @@map("dados_folha_professor")
}

// Cadastro novo pra Prestador de Serviço e Colaborador interno (Professor já
// tem seu próprio cadastro acadêmico, ver DadosFolhaProfessor acima).
model Colaborador {
  id                String      @id @default(uuid())
  nome              String
  cpf               String      @unique
  email             String?
  telefone          String?
  tipoVinculo       TipoVinculo
  cargo             String?
  // Só relevante pra COLABORADOR (passa pelo motor de cálculo igual
  // professor) — Prestador de Serviço usa valor por pagamento avulso, ver
  // PagamentoPrestador.
  salarioBase       Decimal?    @db.Decimal(10, 2)
  numeroDependentes Int         @default(0)
  dataAdmissao      DateTime    @db.Date
  dataDemissao      DateTime?   @db.Date
  ativo             Boolean     @default(true)
  banco             String?
  agencia           String?
  contaBancaria     String?
  observacoes       String?     @db.Text

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  itensFolha ItemFolha[]
  pagamentos PagamentoPrestador[]

  @@map("colaboradores")
}

// Tabelas de INSS/IRRF — cadastro versionado por vigência, editável na tela
// (ADMIN/FINANCEIRO), pra poder corrigir sem deploy quando a tabela oficial
// mudar (normalmente todo ano). `ativa` marca qual vale hoje; sem campo de
// "teto" redundante — o teto do INSS emerge de aplicar a última faixa até o
// limiteFinal dela.
model TabelaInss {
  id             String   @id @default(uuid())
  vigenciaInicio DateTime @db.Date
  ativa          Boolean  @default(true)

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  faixas FaixaInss[]

  @@map("tabelas_inss")
}

model FaixaInss {
  id            String     @id @default(uuid())
  tabelaId      String
  tabela        TabelaInss @relation(fields: [tabelaId], references: [id])
  ordem         Int
  limiteInicial Decimal    @db.Decimal(10, 2)
  limiteFinal   Decimal?   @db.Decimal(10, 2) // null = última faixa, sem limite
  aliquota      Decimal    @db.Decimal(5, 2)  // ex.: 14.00 = 14%

  @@map("faixas_inss")
}

model TabelaIrrf {
  id                        String   @id @default(uuid())
  vigenciaInicio            DateTime @db.Date
  ativa                     Boolean  @default(true)
  valorDeducaoPorDependente Decimal  @db.Decimal(10, 2)

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  faixas FaixaIrrf[]

  @@map("tabelas_irrf")
}

model FaixaIrrf {
  id              String     @id @default(uuid())
  tabelaId        String
  tabela          TabelaIrrf @relation(fields: [tabelaId], references: [id])
  ordem           Int
  limiteInicial   Decimal    @db.Decimal(10, 2)
  limiteFinal     Decimal?   @db.Decimal(10, 2)
  aliquota        Decimal    @db.Decimal(5, 2)
  parcelaDeduzir  Decimal    @db.Decimal(10, 2)

  @@map("faixas_irrf")
}

model FolhaPagamento {
  id                String      @id @default(uuid())
  competenciaMes    Int
  competenciaAno    Int
  status            StatusFolha @default(ABERTA)
  dataFechamento    DateTime?
  dataPagamento     DateTime?

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  itens ItemFolha[]

  @@unique([competenciaMes, competenciaAno])
  @@map("folhas_pagamento")
}

// Um lançamento de professor OU colaborador numa folha — discriminado por
// tipoVinculo + 2 FKs opcionais (mesmo padrão já usado em Emprestimo, no
// módulo Biblioteca, pra "um registro representa A ou B"). Professor não tem
// valor próprio em TipoVinculo porque já é identificado só por professorId
// estar preenchido.
model ItemFolha {
  id                    String              @id @default(uuid())
  folhaId               String
  folha                 FolhaPagamento      @relation(fields: [folhaId], references: [id])
  professorId           String?
  professor             DadosFolhaProfessor? @relation(fields: [professorId], references: [id])
  colaboradorId         String?
  colaborador           Colaborador?        @relation(fields: [colaboradorId], references: [id])

  salarioBase           Decimal             @db.Decimal(10, 2)
  totalProventos        Decimal             @default(0) @db.Decimal(10, 2)
  totalDescontosOutros  Decimal             @default(0) @db.Decimal(10, 2)
  inss                  Decimal             @default(0) @db.Decimal(10, 2)
  irrf                  Decimal             @default(0) @db.Decimal(10, 2)
  fgts                  Decimal             @default(0) @db.Decimal(10, 2) // informativo, não é desconto
  salarioLiquido         Decimal            @db.Decimal(10, 2)
  status                StatusParcelaPagar  @default(PENDENTE)

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  lancamentos ItemFolhaLancamento[]

  @@map("itens_folha")
}

model ItemFolhaLancamento {
  id          String               @id @default(uuid())
  itemFolhaId String
  itemFolha   ItemFolha            @relation(fields: [itemFolhaId], references: [id])
  tipo        TipoLancamentoFolha
  descricao   String
  valor       Decimal              @db.Decimal(10, 2)

  criadoEm DateTime @default(now())

  @@map("itens_folha_lancamentos")
}

// Pagamento avulso de Prestador de Serviço — sem motor de INSS/IRRF (a
// maioria emite nota fiscal como PJ, sem retenção de folha); ISS retido é
// opcional. Ver aviso de risco no topo desta seção sobre autônomo/RPA (fora
// de escopo).
model PagamentoPrestador {
  id                String             @id @default(uuid())
  colaboradorId     String
  colaborador       Colaborador        @relation(fields: [colaboradorId], references: [id])
  data              DateTime           @db.Date
  descricaoServico  String
  numeroNotaFiscal  String?
  valorBruto        Decimal            @db.Decimal(10, 2)
  valorIssRetido    Decimal?           @db.Decimal(10, 2)
  valorLiquido      Decimal            @db.Decimal(10, 2)
  status            StatusParcelaPagar @default(PENDENTE)

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  @@map("pagamentos_prestador")
}

// Acordo de parcelamento de dívida com fornecedor/prestador — espelha
// ContratoMatricula/Parcela (lado do aluno), agora do lado de quem a FIURJ
// paga.
model AcordoPagar {
  id             String            @id @default(uuid())
  fornecedorNome String
  cnpjCpf        String?
  valorTotal     Decimal           @db.Decimal(10, 2)
  numeroParcelas Int
  diaVencimento  Int
  status         StatusAcordoPagar @default(ATIVO)
  observacoes    String?           @db.Text

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  parcelas ParcelaPagar[]

  @@map("acordos_pagar")
}

model ParcelaPagar {
  id             String             @id @default(uuid())
  acordoId       String
  acordo         AcordoPagar        @relation(fields: [acordoId], references: [id])
  numero         Int
  valor          Decimal            @db.Decimal(10, 2)
  dataVencimento DateTime           @db.Date
  dataPagamento  DateTime?          @db.Date
  valorPago      Decimal?           @db.Decimal(10, 2)
  status         StatusParcelaPagar @default(PENDENTE)
  formaPagamento String?

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  @@map("parcelas_pagar")
}

// Espelha CategoriaReceita já existente.
model CategoriaDespesa {
  id          String   @id @default(uuid())
  nome        String
  descricao   String?
  ativa       Boolean  @default(true)

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  gastosFixos    GastoFixo[]
  gastosVariaveis GastoVariavel[]

  @@map("categorias_despesa")
}

model GastoFixo {
  id             String           @id @default(uuid())
  categoriaId    String
  categoria      CategoriaDespesa @relation(fields: [categoriaId], references: [id])
  descricao      String
  valorMensal    Decimal          @db.Decimal(10, 2)
  diaVencimento  Int
  ativo          Boolean          @default(true)

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  @@map("gastos_fixos")
}

model GastoVariavel {
  id          String           @id @default(uuid())
  categoriaId String
  categoria   CategoriaDespesa @relation(fields: [categoriaId], references: [id])
  descricao   String
  valor       Decimal          @db.Decimal(10, 2)
  data        DateTime         @db.Date
  observacoes String?          @db.Text

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  @@map("gastos_variaveis")
}
