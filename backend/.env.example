# ============================================================
# Copie para .env e preencha os valores reais.
# NUNCA commite o .env no repositório.
# ============================================================

# Banco de dados (PostgreSQL gerenciado)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/fiurj_plataforma?schema=public"

# JWT
JWT_SECRET="troque-por-um-segredo-longo-e-aleatorio"
JWT_EXPIRES_IN="1d"

# App
PORT=3001
NODE_ENV=development

# Sentry (deixe vazio em dev para não enviar eventos)
SENTRY_DSN=""
