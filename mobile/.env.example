# Copie para .env e ajuste. Precisa do prefixo EXPO_PUBLIC_ pra ficar
# disponível no app (client-side) — não coloque segredo aqui.
#
# Em desenvolvimento com Expo Go no celular físico, "localhost" não funciona
# (é o localhost do celular, não do seu PC) — use o IP da sua máquina na rede
# local, ex: EXPO_PUBLIC_API_URL=http://192.168.0.10:3001/api/v1
EXPO_PUBLIC_API_URL=http://localhost:3001/api/v1

# URL do frontend web (usado pela WebView de documentos/impressão — ver README).
EXPO_PUBLIC_WEB_URL=http://localhost:3000
